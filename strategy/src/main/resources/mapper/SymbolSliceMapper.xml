<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cmbc.strategy.dao.SymbolSliceMapper">

    <resultMap id="symbolSliceResultMap" type="com.cmbc.strategy.domain.entity.SymbolSliceEntity">
        <result property="configId" column="config_id"/>
        <result property="domesticType" column="domestic_type"/>
        <result property="symbol" column="symbol"/>
        <result property="tradeStartTime" column="trade_start_time"/>
        <result property="tradeEndTime" column="trade_end_time"/>
        <result property="triggerLongPosition" column="trigger_long_position"/>
        <result property="endLongPosition" column="end_long_position"/>
        <result property="triggerShortPosition" column="trigger_short_position"/>
        <result property="endShortPosition" column="end_short_position"/>
        <result property="fxSymbol" column="fx_symbol"/>
        <result property="groupName" column="group_name"/>
        <result property="groupId" column="group_id"/>
    </resultMap>

    <select id="selectById" parameterType="string" resultMap="symbolSliceResultMap">
        SELECT * FROM gold_hedge_contract_config WHERE group_id = #{configId}
    </select>

</mapper>
