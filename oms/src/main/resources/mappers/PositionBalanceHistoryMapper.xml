<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cmbc.oms.dao.PositionBalanceHistoryMapper">

    <resultMap id="BaseResultMap" type="com.cmbc.oms.domain.exposure.entity.PositionBalanceHistoryEntity">
        <result column="position_id" property="positionId" />
        <result column="system_id" property="systemId" />
        <result column="folder_id" property="folderId" />
        <result column="symbol" property="symbol" />
        <result column="long_qty" property="longQty" />
        <result column="long_weight" property="longWeight" />
        <result column="long_amount" property="longAmount" />
        <result column="short_qty" property="shortQty" />
        <result column="short_weight" property="shortWeight" />
        <result column="short_amount" property="shortAmount" />
        <result column="update_time" property="updateTime" />
        <result column="create_time" property="createTime" />
        <result column="statistic_date" property="statisticDate" />
        <result column="domestic_type" property="domesticType" />
        <result column="unit" property="unit" />
    </resultMap>

    <insert id="insert" parameterType="com.cmbc.oms.domain.exposure.entity.PositionBalanceHistoryEntity">
        INSERT INTO position_balance_history (
            position_id,
            system_id,
            folder_id,
            symbol,
            long_qty,
            long_weight,
            long_amount,
            short_qty,
            short_weight,
            short_amount,
            update_time,
            create_time,
            statistic_date,
            domestic_type,
            unit
        ) VALUES (
            #{positionId},
            #{systemId},
            #{folderId},
            #{symbol},
            #{longQty},
            #{longWeight},
            #{longAmount},
            #{shortQty},
            #{shortWeight},
            #{shortAmount},
            #{updateTime},
            #{createTime},
            #{statisticDate},
            #{domesticType},
            #{unit}
        )
    </insert>

</mapper>
